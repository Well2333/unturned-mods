# ---- .NET build output ----
bin/
obj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
*.user
*.suo
*.userprefs

# ---- NuGet packages produced by GeneratePackageOnBuild ----
*.nupkg
*.snupkg

# ---- IDE ----
.vs/
.idea/
.vscode/
*.DotSettings.user

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Local test server / deployment artifacts ----
# A local Unturned + OpenMod server used for manual testing should live here
# and never be committed.
/.localserver/
/artifacts/

# ---- Assembled plugin artifacts from scripts/build.sh ----
# build/ is the default output dir; everything there is generated EXCEPT the
# version-controlled plugin templates.
/build/*
!/build/templates/

# ---- Misc ----
*.log
image*.png
