# ---- .NET build output ----
bin/
obj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
*.user
*.suo
*.userprefs

# ---- NuGet packages produced by GeneratePackageOnBuild ----
*.nupkg
*.snupkg

# ---- IDE ----
.vs/
.idea/
.vscode/
*.DotSettings.user

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Local test server / deployment artifacts ----
# A local Unturned + OpenMod server used for manual testing should live here
# and never be committed.
/.localserver/
/artifacts/
# Local-only AI memory (may contain private host aliases or deployment context).
# Never commit or publish this directory.
/.local-memory/

# ---- Assembled plugin artifacts from scripts/build.sh ----
# build/ is the default output dir; everything there is generated EXCEPT the
# version-controlled plugin templates.
/build/*
!/build/templates/

# ---- Misc ----
*.log
image*.png

# ---- Local project research sources / linked worktrees ----
# External research repositories and auxiliary worktrees are project-level local state,
# not remote-operation memory. Keep them outside .local-memory and out of commits.
/research/external/
/.worktrees/

# Local inspection helpers may contain machine-specific assembly paths.
# Keep them available locally, but do not treat them as supported repository tools.
/tools/
