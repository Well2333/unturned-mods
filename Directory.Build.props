<Project>

  <!--
    Shared MSBuild properties applied to EVERY project in this repository.
    This guarantees a consistent build/runtime environment across all plugins,
    which is exactly what we want for a multi-plugin OpenMod repo.

    Plugin-specific settings (GeneratePackageOnBuild, package tags, embedded
    resources) live in each plugin's own .csproj — see build/templates/plugin.
  -->

  <PropertyGroup>
    <!-- OpenMod Unturned plugins target netstandard2.1. Do NOT change per-project. -->
    <TargetFramework>netstandard2.1</TargetFramework>

    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>

    <!-- Treat nullable violations as errors; matches the official OpenMod template. -->
    <WarningsAsErrors>nullable</WarningsAsErrors>
    <NoWarn>$(NoWarn);NU1701;NU1702;CS0436</NoWarn>

    <!-- Deterministic, reproducible builds. -->
    <Deterministic>true</Deterministic>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>

    <!-- Central Package Management: versions are defined in Directory.Packages.props. -->
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>

    <!-- Shared package metadata (override per plugin where needed). -->
    <Authors>well404</Authors>
    <Company>well404</Company>
    <!-- CC BY-NC-SA 4.0 is not an OSI/FSF license, so it is shipped as a bundled
         license file (PackageLicenseFile) rather than an SPDX expression. -->
    <PackageLicenseFile>LICENSE</PackageLicenseFile>
    <Copyright>Copyright (c) well404. Licensed under CC BY-NC-SA 4.0.</Copyright>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/Well2333/unturned-mods</RepositoryUrl>
    <PackageProjectUrl>https://github.com/Well2333/unturned-mods</PackageProjectUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <!-- Symbols + SourceLink for debuggable published packages. -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <!-- Set to true by CI for deterministic, source-linked builds. -->
    <ContinuousIntegrationBuild Condition="'$(CI)' == 'true'">true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <!-- Pack a README + LICENSE into every package (only affects packable projects).

       README selection: prefer the plugin's OWN README.md (in its project directory) so
       each NuGet package page shows plugin-specific docs instead of the whole-repo README;
       fall back to the repo-root README for any packable project that lacks its own.
       Both land at \README.md, matching <PackageReadmeFile>README.md above, so this works
       for local `dotnet pack` (scripts/build.sh) and the CI publish workflow identically.

       For the plugin's own README we Remove any default None item for it first, then
       Include it with Pack=true (Remove is a harmless no-op if it wasn't a default item;
       this avoids both a duplicate-item error and the "readme not packed" NU5039). The
       repo-root README lives outside the project tree, so it just uses Include. -->
  <ItemGroup Condition="Exists('$(MSBuildProjectDirectory)/README.md')">
    <None Remove="README.md" />
    <None Include="$(MSBuildProjectDirectory)/README.md" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>
  <ItemGroup Condition="!Exists('$(MSBuildProjectDirectory)/README.md')">
    <None Include="$(MSBuildThisFileDirectory)README.md" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>
  <ItemGroup>
    <None Include="$(MSBuildThisFileDirectory)LICENSE" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>

  <!-- SourceLink: maps published symbols back to GitHub source. -->
  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>

</Project>
